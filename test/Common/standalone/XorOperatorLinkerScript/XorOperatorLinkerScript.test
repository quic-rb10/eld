#---XorOperatorLinkerSxript.test--------------------------- Executable -----------------#
#BEGIN_COMMENT
# This test checks teh result of xor operator supported by the linkerscript.
#END_COMMENT
#START_TEST
RUN: %clang %clangopts -c %p/Inputs/1.c -o %t1.o -ffunction-sections
RUN: %link %linkopts -T %p/Inputs/script.t %t1.o -o %t2.out
RUN: %readelf -l %t2.out | %filecheck %s

#CHECK: 1100
#END_TEST
